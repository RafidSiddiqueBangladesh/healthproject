# Environment Configuration
NODE_ENV=production
PORT=5000

# Render public backend URL (replace with your Render service URL)
RENDER_EXTERNAL_URL=https://your-backend.onrender.com

# Frontend URLs allowed by CORS
# Add your Netlify domain and local development domains.
FRONTEND_URL=https://your-frontend.netlify.app
FRONTEND_URLS=https://your-frontend.netlify.app,http://localhost:64616,http://127.0.0.1:64616

# Supabase (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional JWT values (only if used by custom flows)
JWT_SECRET=change_this_in_production
JWT_EXPIRE=7d

# OpenRouter AI (text + vision)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_MODEL=google/gemini-2.0-flash-lite-001
OPENROUTER_TEXT_MODEL=google/gemini-2.0-flash-lite-001
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-lite-001
OPENROUTER_SITE_URL=https://your-backend.onrender.com
OPENROUTER_APP_NAME=NutriCare Backend

# YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key

# OCR Configuration
TESSERACT_LANG=eng

# File Upload
MAX_FILE_SIZE=5000000
UPLOAD_PATH=./uploads/

# Email Configuration (optional)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
